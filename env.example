# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Semantic cache similarity threshold (0.0 – 1.0)
# Higher = stricter match required before serving cached answer
CACHE_SIMILARITY_THRESHOLD=0.92

# TTL for cached responses (seconds); 0 = no expiry
CACHE_TTL=86400

# ─── Vector Store (ChromaDB) ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# ─── Ingestion ────────────────────────────────────────────────────────────────
DATA_DIR=./data/raw
CHUNK_SIZE=512
CHUNK_OVERLAP=64
BATCH_SIZE=500

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.35

# ─── Evaluation ───────────────────────────────────────────────────────────────
EVAL_DATASET_PATH=./data/eval_dataset.json
EVAL_RESULTS_DIR=./data/eval_results

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
